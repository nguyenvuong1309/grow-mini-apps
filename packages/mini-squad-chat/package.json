{
  "name": "mini-squad-chat",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "start": "react-native webpack-start --port 9001",
    "start:standalone": "STANDALONE=true react-native webpack-start --port 9001",
    "bundle:ios": "react-native webpack-bundle --platform ios --entry-file src/index.js --dev false --bundle-output build/ios/main.jsbundle",
    "bundle:android": "react-native webpack-bundle --platform android --entry-file src/index.js --dev false --bundle-output build/android/main.jsbundle",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,js,jsx}'"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@supabase/supabase-js": "^2.99.1",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-fast-image": "^8.6.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.7",
    "react-native-reanimated": "^4.2.3",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-worklets": "^0.8.1",
    "react-redux": "^9.2.0",
    "redux-saga": "^1.4.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@callstack/repack": "^5.2.5",
    "@callstack/repack-plugin-reanimated": "^5.2.5",
    "@module-federation/enhanced": "0.22.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@rspack/core": "^1.7.11",
    "@swc/helpers": "^0.5.20",
    "@types/react": "^19.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.57.1",
    "prettier": "2.8.8",
    "typescript": "^5.8.3"
  }
}
